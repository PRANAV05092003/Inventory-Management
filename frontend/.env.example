# Backend API URL
#
# Local Vite dev (uses proxy when empty — recommended):
# VITE_API_URL=
#
# Or point directly at the API:
# VITE_API_URL=http://localhost:8000
#
# Docker Compose production build (nginx proxies API — leave empty):
# VITE_API_URL=
#
# Vercel production (set in Vercel project Environment Variables):
# VITE_API_URL=https://your-backend.onrender.com
#
VITE_API_URL=http://localhost:8000

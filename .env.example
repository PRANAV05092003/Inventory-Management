# Docker Compose — copy to .env in project root (optional overrides)

# PostgreSQL
POSTGRES_DB=inventory_db
POSTGRES_USER=inventory_user
POSTGRES_PASSWORD=change_me_secure_password
POSTGRES_PORT=5432

# Services
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Backend
APP_NAME=Inventory Management API
APP_VERSION=1.0.0
DEBUG=false
WEB_CONCURRENCY=2
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# Frontend build (leave empty for Docker Compose nginx proxy)
VITE_API_URL=

# Docker Hub image tags (optional)
DOCKERHUB_USERNAME=your-dockerhub-username
IMAGE_TAG=latest

# Application
APP_NAME=Inventory Management API
APP_VERSION=1.0.0
DEBUG=false

# Uvicorn workers (production)
WEB_CONCURRENCY=2

# CORS — comma-separated allowed origins (no spaces required)
# Local dev (Vite): http://localhost:5173
# Docker Compose frontend: http://localhost:3000
# Vercel: https://your-app.vercel.app
# Render static site: https://your-frontend.onrender.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# PostgreSQL (local / Docker Compose)
POSTGRES_DB=inventory_db
POSTGRES_USER=inventory_user
POSTGRES_PASSWORD=change_me_secure_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full database URL (recommended for Render + Neon)
# Neon example (include sslmode=require):
# DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://inventory_user:change_me_secure_password@localhost:5432/inventory_db
